---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { entrySlug } from '../../lib/url';
import Card from '../../components/Card.astro';
import { byWeightThenDate } from '../../lib/sort';
import { Content as Intro } from '../../content/pages/projects-intro.md';
import { Content as More } from '../../content/pages/projects-more.md';

const items = (await getCollection('projects')).sort(byWeightThenDate);
const crumbs = [{ href: '/', label: 'Home' }];
---
<PageLayout title="My Projects" crumbs={crumbs} current="/projects/">
  <div class="grid gap-4 p-6 bg-neutral-900 drop-shadow-2xl rounded-t-md border-b-2 border-b-primary">
    <h1 class="text-2xl">My Projects</h1>
    <div class="post-content"><Intro /><More /></div>
    <div class="grid xl:grid-cols-3 md:grid-cols-2 gap-6 my-6 cards-reveal-container">
      {items.map((e) => (
        <Card href={`/projects/${entrySlug(e)}/`} title={e.data.title} shortdesc={e.data.shortdesc} feature={e.data.feature} tags={e.data.tags} />
      ))}
    </div>
  </div>
</PageLayout>
