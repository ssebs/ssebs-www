---
import { Image } from 'astro:assets';
import meWedding from '../assets/me_wedding.jpg';

interface Props {}
---
<div class="hero grid items-center justify-center my-6 w-full">
    <div class="hero-content grid items-center justify-center md:max-w-4xl w-full">
        <div class="p-6 grid md:grid-cols-2">
            <Image class="hero-image mx-auto rounded-md border-2 border-primary" title="A photo of my at my wedding." alt="A photo of my at my wedding." src={meWedding}
                width={300} height={300} />

            <div class="flex flex-col justify-between my-6 md:text-lg text-white">
                <h1 class="hero-title md:text-3xl text-2xl mb-4">Hey, I'm Sebastian Safari</h1>
                <p class="hero-text">
                    I'm a full-stack software engineer who likes to make stuff. I love to code, build side projects, and figure things out.
                </p>
                <div class="flex flex-wrap mx-0 mt-6 gap-4">
                    <a href="/projects/" class="hero-cta">
                        <div
                            class="p-2 rounded-xl border border-quinary bg-quinary text-neutral-900 hover:bg-secondary hover:border-secondary hover:text-white transition-all duration-300 btn-glow">
                            See my projects
                        </div>
                    </a>
                    <a href="/about/" class="hero-cta">
                        <div class="p-2 rounded-xl border border-primary text-primary hover:bg-secondary hover:border-secondary hover:text-white font-semibold transition-all duration-300 btn-glow">
                            About me
                        </div>
                    </a>
                    <a href="/blog/" class="hero-cta">
                        <div class="p-2 rounded-xl border border-white-dim text-white-dim hover:bg-secondary hover:border-secondary hover:text-white font-semibold transition-all duration-300 btn-glow">
                            Check out my blog
                        </div>
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
