---
import { Image } from 'astro:assets';
import meWedding from '../assets/me_wedding.jpg';
import Socials from './Socials.astro';

interface Props {
  current: string;
}

const { current } = Astro.props as Props;
---
<div class="sidebar-animate flex gap-2 flex-col bg-neutral-900 p-3 drop-shadow-lg rounded-t-xl border-b-2 border-primary">
    <div class="mx-3">
        <div class="sidebar-img-wrapper mx-auto lg:w-full max-w-[300px] my-4 border-2 border-primary">
            <Image class="w-full"
                title="A photo of my at my wedding." alt="A photo of my at my wedding." src={meWedding} />
        </div>

        <div class="border-b border-neutral-600 flex flex-col gap-0 justify-center align-middle pb-2 mb-2">
            <h4 class="text-lg font-semibold mb-0">Sebastian Safari</h4>
            <p class="text-sm">Full-Stack Software Engineer</p>
        </div>
        <p class="text-white-dim">Professional fixer, hobbyist figure-outer.</p>

        <div class="grid py-3">
            {current !== '/about/' && (
            <a href="/about/"
                class="rounded-md underline border-b-1 border-b-primary text-quaternary hover:text-quinary transition-colors duration-300">
                Who am I?
            </a>
            )}
            {current !== '/contact/' && (
            <a href="/contact/"
                class="rounded-md underline border-b-1 border-b-primary text-quaternary hover:text-quinary transition-colors duration-300">
                Contact me!
            </a>
            )}
            {current !== '/blog/' && (
            <a href="/blog/"
                class="rounded-md underline border-b-1 border-b-primary text-quaternary hover:text-quinary transition-colors duration-300">
                Dive into my blog!
            </a>
            )}
        </div>

        <div class="flex justify-center flex-wrap gap-3 py-3">
            <a href="/tags/python/"
                class="px-2 py-1 rounded-md border border-quinary text-quinary hover:bg-quinary hover:text-black transition-all duration-300 tag-hover">python</a>
            <a href="/tags/golang/"
                class="px-2 py-1 rounded-md border border-quinary text-quinary hover:bg-quinary hover:text-black transition-all duration-300 tag-hover">golang</a>
            <a href="/tags/webdev/"
                class="px-2 py-1 rounded-md border border-quaternary text-quaternary hover:bg-quaternary hover:text-black transition-all duration-300 tag-hover">Web
                Dev</a>
            <a href="/about/"
                class="px-2 py-1 rounded-md border border-quaternary text-quaternary hover:bg-quaternary hover:text-black transition-all duration-300 tag-hover">DevOps</a>
            <a href="/projects/"
                class="px-2 py-1 rounded-md border border-primary text-primary hover:bg-primary hover:text-black transition-all duration-300 tag-hover">
                More projects
            </a>
        </div>
        <ul class="flex justify-around gap-3 py-3">
            <Socials color="#33ffe7" iconsize="1.75rem" />
        </ul>
    </div>
</div>
