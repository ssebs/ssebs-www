---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  title?: string;
  class?: string;
  width?: number | string;
}

const { src, title, class: className, width } = Astro.props as Props;
const numericWidth = typeof width === 'number' ? width : width !== undefined ? parseInt(width, 10) : undefined;
---
<Image src={src} alt={title ?? ''} class={className} width={numericWidth} />
