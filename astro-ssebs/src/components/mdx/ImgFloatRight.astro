---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  width?: number | string;
  loading?: 'eager' | 'lazy';
}

const { src, alt = '', width, loading } = Astro.props as Props;

// Derive a [w, w*2] widths set from the numeric portion of `width` (e.g. "300px" -> 300).
const numericWidth = typeof width === 'number' ? width : parseInt(String(width ?? ''), 10);
const widths = Number.isFinite(numericWidth) && numericWidth > 0 ? [numericWidth, numericWidth * 2] : undefined;
---
<Image
  src={src}
  alt={alt}
  class="custom-float-right ml-3"
  width={widths ? widths[0] : undefined}
  widths={widths}
  loading={loading}
/>
