---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  width?: number | string;
  title?: string;
  class?: string;
}

const { src, alt = '', width, title, class: className = 'block' } = Astro.props as Props;
const numericWidth = typeof width === 'number' ? width : width !== undefined ? parseInt(width, 10) : undefined;
---
<Image src={src} alt={alt} class={className} width={numericWidth} title={title} />
