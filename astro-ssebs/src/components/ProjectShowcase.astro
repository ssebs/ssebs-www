---
interface Props {
  title: string;
  href: string;
  summaryHtml: string;
  noC2A?: boolean;
  c2aText?: string;
}

const { title, href, summaryHtml, noC2A, c2aText } = Astro.props as Props;
---
<section class="bg-neutral-900 grid justify-center w-full pb-6">
    <div class="grid lg:max-w-6xl md:max-w-4xl w-full p-6 justify-start text-xl ">
        <h3 class="text-3xl font-semibold">
            A little bit more about the
            <a href={href} class="text-quinary underline font-normal">{title}</a>
        </h3>
         <div class="text-white-dim grid text-base">
            <div class="post-content" set:html={summaryHtml} />
         </div>
    </div>
    {/* C2A */}
    {!noC2A && (
    <div class="mb-6">
        <a class="text-base p-3 max-w-fit bg-quaternary text-neutral-900 hover:bg-quinary font-medium rounded-md transition-colors duration-300 btn-glow"
            href={href}>
            {c2aText || 'See more...'}
        </a>
    </div>
    )}
</section>
