---
import { Image } from 'astro:assets';
import logo from '../assets/RocketOnly.png';
import { nav, site, socials } from '../config';
import Socials from './Socials.astro';

const authorLink = socials.find((s) => s.name === 'linkedin')!.link;
---
<footer id="site-footer" class="bg-secondary min-h-64">
    <div class="grid justify-center p-6">
        <h5 class="footer-title text-3xl text-white font-thin text-center p-8">Thanks for stopping by!</h5>
        <div class="footer-divider w-full max-w-2xl mx-auto mb-6"></div>
        <div
            class="flex lg:flex-row lg:items-start lg:max-w-6xl flex-col justify-between items-start w-full lg:mt-6 lg:p-6 mt-4 p-4 gap-12 text-lg">
            <div class="footer-section flex justify-between items-end gap-6 min-w-80">
                <Image src={logo} width={128} alt="logo" class="logo-hover footer-logo" />
                <div class="flex flex-col items-start gap-2 min-w-48">
                    <a href="/" class="font-medium hover:text-quinary transition-colors duration-300">
                        {site.title}
                    </a>
                    <ul class="space-y-1">
                        {nav.map((item) => (
                        <li>
                            <a href={item.href} title={item.label}
                                class="footer-link text-quinary hover:text-quaternary transition-colors duration-300">
                                {item.shortDesc}
                            </a>
                        </li>
                        ))}
                    </ul>
                </div>
            </div>

            <div class="footer-section grid gap-2 max-w-md text-base font-normal">
                <h5 class="text-xl font-medium">Why <span class="text-quaternary">ssebs</span>?</h5>
                <div class="footer-story space-y-2 text-gray-300">
                    <p>
                        Back when I needed my first username, I wanted something using my initials.
                    </p>
                    <p>
                        "Seb" was taken. "SebS" was taken too. So I got creative and wrapped it with an extra "S" from my last name.
                    </p>
                    <p class="text-quaternary font-medium">
                        ssebs = S + Seb + S
                    </p>
                    <p class="text-sm text-gray-400 italic">Riveting origin story, right?</p>
                </div>
            </div>

            <div class="footer-section min-w-32 flex flex-col gap-3">
                <div class="text-xl font-medium">Let's Connect</div>
                <ul class="flex gap-3">
                    <Socials color="#33ffe7" iconsize="2rem" />
                </ul>
                <p class="text-sm text-gray-400 mt-2">Always happy to chat!</p>
            </div>

        </div>
    </div>
    <div class="footer-copyright text-center bg-neutral-700 p-6">
        <span id="copyright-year">&copy;2024 - &lt;this should be replaced by js&gt;</span>
    </div>
</footer>

<script define:vars={{ fromYear: site.copyrightStartYear, authorLink, author: site.author }} is:inline>
    // Set copyright year from current date
    const copyElement = document.getElementById("copyright-year");
    const current = new Date().getFullYear();

    const authorHTML = `<a
                            href="${authorLink}"
                            class="text-quaternary hover:text-quinary transition-colors duration-300" target="_blank"
                            >
                                ${author}
                        </a>`;

    if (current === fromYear) {
        copyElement.innerHTML = `&copy;${current} | ${authorHTML}`;
    } else {
        copyElement.innerHTML = `&copy;${fromYear} - ${current} | ${authorHTML}`;
    }

    // Footer scroll animation
    const footer = document.getElementById('site-footer');
    const footerAnimatedElements = footer.querySelectorAll('.footer-title, .footer-divider, .footer-section, .footer-copyright, .footer-logo');

    const footerObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                footerAnimatedElements.forEach(el => el.classList.add('animate'));
                footerObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });

    footerObserver.observe(footer);

    // Card scroll reveal animation
    const cards = document.querySelectorAll('.card-reveal');

    const cardRevealObserver = new IntersectionObserver(
    (entries, observer) => {
        entries.forEach(entry => {
        if (!entry.isIntersecting) return;

        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
        });
    },
    {
        threshold: 0.15,
        rootMargin: '0px 0px -10% 0px'
    }
    );

    cards.forEach(card => cardRevealObserver.observe(card));

</script>
